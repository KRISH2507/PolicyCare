# ============================================================
# AarogyaAid Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# SQLite database file path (relative to backend/ directory).
# For production, replace with a PostgreSQL URL:
#   postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./aarogyaaid.db

# OpenAI API key — used for GPT-4o-mini (recommendations + chat)
# and text-embedding-3-small (vector embeddings).
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Secret key for signing JWT tokens. Use a long random string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret-string

# Admin credentials. The admin account is NOT stored in the database —
# it is validated directly against these environment variables.
# Change these before any deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-deploy

# Path to the ChromaDB persistent storage directory.
# Relative to backend/ directory. Created automatically on first run.
CHROMA_PATH=./chroma_db
